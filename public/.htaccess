# VARIABLES DE ENTORNO SEGURAS
SetEnv DB_PASS "Asisve01**"
SetEnv SMTP_PASS "Asisve$77"

# 1. BLOQUEAR ACCESO A ARCHIVOS SENSIBLES
<FilesMatch "^\.env|^\.git|^\.ht">
    Order allow,deny
    Deny from all
</FilesMatch>

# 2. CONFIGURACIÓN DE SEGURIDAD AVANZADA (Headers)
<IfModule mod_headers.c>
    # Proteger contra Clickjacking
    Header set X-Frame-Options "SAMEORIGIN"
    # Proteger contra Sniffing de tipos de archivo
    Header set X-Content-Type-Options "nosniff"
    # Forzar HTTPS (HSTS) - Solo si tienes SSL activo
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    # Protección básica XSS
    Header set X-XSS-Protection "1; mode=block"
    # Política de Referencia
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Restricción de CORS (Dominios autorizados)
    # Temporalmente permitimos Netlify y Hostinger para tus pruebas
    SetEnvIf Origin "https://asisve.netlify.app" ALLOWED_ORIGIN=$0
    SetEnvIf Origin "https://forestgreen-pelican-956861.hostingersite.com" ALLOWED_ORIGIN=$0
    SetEnvIf Origin "https://asisve.org" ALLOWED_ORIGIN=$0
    
    Header set Access-Control-Allow-Origin %{ALLOWED_ORIGIN}e env=ALLOWED_ORIGIN
    Header set Access-Control-Allow-Methods "POST, OPTIONS"
    Header set Access-Control-Allow-Headers "Content-Type"
</IfModule>

# 3. SEGURIDAD GENERAL
# Ocultar la firma del servidor
ServerSignature Off

# Evitar el listado de directorios
Options -Indexes

# 4. MANEJO DE RUTAS ASTRO (Opcional, para SPA)
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Si el archivo o directorio no existe, redirigir a index.html (Útil para Astro)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    # No redirigir si la ruta empieza por /api/
    RewriteCond %{REQUEST_URI} !^/api/
    RewriteRule ^ index.html [L]
</IfModule>
