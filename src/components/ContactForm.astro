  <div class="space-y-2">
    <label for="Asunto" class="text-sm font-bold text-dark/70 ml-1">Asunto *</label>
    <input 
      type="text" 
      name="Asunto" 
      id="Asunto" 
      required 
      class="w-full px-5 py-4 rounded-2xl border border-gray-100 bg-gray-50/50 focus:bg-white focus:ring-4 focus:ring-primary/5 focus:border-primary outline-none transition-all duration-300 placeholder:text-gray-300"
      placeholder="¿Cómo podemos ayudarte?"
    />
  </div>

  <div class="space-y-2">
    <label for="Mensaje" class="text-sm font-bold text-dark/70 ml-1">Mensaje *</label>
    <textarea 
      name="Mensaje" 
      id="Mensaje" 
      rows="4" 
      required 
      class="w-full px-5 py-4 rounded-2xl border border-gray-100 bg-gray-50/50 focus:bg-white focus:ring-4 focus:ring-primary/5 focus:border-primary outline-none transition-all duration-300 placeholder:text-gray-300 resize-none overflow-hidden h-32"
      placeholder="Escribe tu mensaje aquí..."
    ></textarea>
  </div>

  <button 
    type="submit" 
    id="formSubmit"
    class="w-full bg-primary hover:bg-dark text-white font-black py-5 rounded-2xl transition-all shadow-2xl hover:shadow-primary/30 flex items-center justify-center gap-3 group relative overflow-hidden active:scale-[0.98]"
  >
    <span class="z-10 relative flex items-center gap-3">
      Enviar mensaje
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1 group-hover:-translate-y-1"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
    </span>
    <div class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
  </button>
  
  <div id="formStatus" class="hidden text-center p-5 rounded-2xl font-bold border-2 transition-all duration-500 scale-95 opacity-0"></div>
</form>

<script>
  import { ApiClient } from '../services/api.client';

  const form = document.querySelector('#contactForm') as HTMLFormElement;
  const statusEl = document.querySelector('#formStatus') as HTMLDivElement;
  const submitBtn = document.querySelector('#formSubmit') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const dataObj = Object.fromEntries(formData);
    
    // Estado de carga
    submitBtn.disabled = true;
    submitBtn.classList.add('opacity-50', 'pointer-events-none');
    
    statusEl.textContent = 'Procesando tu mensaje...';
    statusEl.className = 'text-center p-5 rounded-2xl font-bold border-2 bg-blue-50/50 border-blue-200 text-blue-600 animate-pulse block scale-100 opacity-100';
    statusEl.classList.remove('hidden');

    // Realizar la petición a nuestra nueva API en PHP
    const result = await ApiClient.post('/contact.php', dataObj);

    // Reset de botón
    submitBtn.disabled = false;
    submitBtn.classList.remove('opacity-50', 'pointer-events-none');

    if (result.success) {
      statusEl.textContent = result.message || '¡Mensaje enviado con éxito!';
      statusEl.className = 'text-center p-5 rounded-2xl font-bold border-2 bg-green-50/50 border-green-200 text-green-700 block scale-100 opacity-100';
      form.reset();
      
      // Ocultar mensaje después de 5 segundos
      setTimeout(() => {
        statusEl.classList.add('opacity-0', 'scale-95');
        setTimeout(() => statusEl.classList.add('hidden'), 500);
      }, 5000);
    } else {
      statusEl.textContent = result.message || 'Error: No se pudo enviar el mensaje.';
      statusEl.className = 'text-center p-5 rounded-2xl font-bold border-2 bg-red-50/50 border-red-200 text-red-700 block scale-100 opacity-100';
    }
  });
</script>

