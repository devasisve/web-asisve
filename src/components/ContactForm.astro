<form id="contactForm" class="space-y-6 bg-white p-6 sm:p-10 rounded-3xl shadow-2xl border border-gray-100/50">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="space-y-2">
      <label for="nombre" class="text-sm font-bold text-dark/70 ml-1">Nombre completo *</label>
      <input 
        type="text" 
        name="nombre" 
        id="nombre" 
        required 
        class="w-full px-5 py-4 rounded-2xl border border-gray-100 bg-gray-50/50 focus:bg-white focus:ring-4 focus:ring-primary/5 focus:border-primary outline-none transition-all duration-300 placeholder:text-gray-300"
        placeholder="Tu nombre completo..."
      />
    </div>
    <div class="space-y-2">
      <label for="email" class="text-sm font-bold text-dark/70 ml-1">Correo electrónico *</label>
      <input 
        type="email" 
        name="email" 
        id="email" 
        required 
        class="w-full px-5 py-4 rounded-2xl border border-gray-100 bg-gray-50/50 focus:bg-white focus:ring-4 focus:ring-primary/5 focus:border-primary outline-none transition-all duration-300 placeholder:text-gray-300"
        placeholder="ejemplo@correo.com"
      />
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="space-y-2">
      <label for="phone" class="text-sm font-bold text-dark/70 ml-1">Teléfono (WhatsApp)</label>
      <input 
        type="tel" 
        name="phone" 
        id="phone" 
        class="w-full px-5 py-4 rounded-2xl border border-gray-100 bg-gray-50/50 focus:bg-white focus:ring-4 focus:ring-primary/5 focus:border-primary outline-none transition-all duration-300 placeholder:text-gray-300"
        placeholder="+34 000 000 000"
      />
    </div>
    <div class="space-y-2">
      <label for="codigopostal" class="text-sm font-bold text-dark/70 ml-1">Código Postal</label>
      <input 
        type="text" 
        name="codigopostal" 
        id="codigopostal" 
        class="w-full px-5 py-4 rounded-2xl border border-gray-100 bg-gray-50/50 focus:bg-white focus:ring-4 focus:ring-primary/5 focus:border-primary outline-none transition-all duration-300 placeholder:text-gray-300"
        placeholder="28001"
      />
    </div>
  </div>

  <div class="space-y-2">
    <label for="Asunto" class="text-sm font-bold text-dark/70 ml-1">Asunto *</label>
    <input 
      type="text" 
      name="Asunto" 
      id="Asunto" 
      required 
      class="w-full px-5 py-4 rounded-2xl border border-gray-100 bg-gray-50/50 focus:bg-white focus:ring-4 focus:ring-primary/5 focus:border-primary outline-none transition-all duration-300 placeholder:text-gray-300"
      placeholder="¿Cómo podemos ayudarte?"
    />
  </div>

  <div class="space-y-2">
    <label for="Mensaje" class="text-sm font-bold text-dark/70 ml-1">Mensaje *</label>
    <textarea 
      name="Mensaje" 
      id="Mensaje" 
      rows="4" 
      required 
      class="w-full px-5 py-4 rounded-2xl border border-gray-100 bg-gray-50/50 focus:bg-white focus:ring-4 focus:ring-primary/5 focus:border-primary outline-none transition-all duration-300 placeholder:text-gray-300 resize-none overflow-hidden h-32"
      placeholder="Escribe tu mensaje aquí..."
    ></textarea>
  </div>

  <div class="flex items-start gap-3 py-2">
    <input 
      type="checkbox" 
      name="privacy" 
      id="privacy" 
      required 
      class="mt-1 w-5 h-5 rounded border-gray-200 text-primary focus:ring-primary transition-all cursor-pointer accent-primary"
    />
    <label for="privacy" class="text-sm text-gray-500 leading-relaxed cursor-pointer select-none">
      Al hacer click aceptas nuestros <span class="text-dark font-bold">Términos y Condiciones</span> y <span class="text-dark font-bold">Políticas de Privacidad</span>.
      <button type="button" id="openPrivacy" class="text-primary font-bold hover:underline ml-1 cursor-pointer">(Leer más)</button>
    </label>
  </div>

  <button 
    type="submit" 
    id="formSubmit"
    class="w-full bg-primary hover:bg-dark text-white font-black py-5 rounded-2xl transition-all shadow-2xl hover:shadow-primary/30 flex items-center justify-center gap-3 group relative overflow-hidden active:scale-[0.98]"
  >
    <span class="z-10 relative flex items-center gap-3">
      Enviar mensaje
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1 group-hover:-translate-y-1"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
    </span>
    <div class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300"></div>
  </button>
  
  <div id="formStatus" class="hidden text-center p-5 rounded-2xl font-bold border-2 transition-all duration-500 scale-95 opacity-0"></div>
</form>

<!-- Modal de Privacidad -->
<div id="privacyModal" class="fixed inset-0 z-60 items-center justify-center bg-dark/60 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 hidden">
  <div id="privacy-modal-content" class="relative w-[calc(100%-2rem)] max-w-2xl bg-white rounded-3xl shadow-2xl overflow-hidden transform scale-95 transition-transform duration-300">
    <!-- Header -->
    <div class="px-8 py-6 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
      <div class="w-10"></div> <!-- Spacer -->
      <h3 class="text-xl font-black text-dark flex items-center justify-center gap-2 flex-1 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Privacidad y Términos
      </h3>
      <button type="button" id="closePrivacyIcon" class="p-2 hover:bg-gray-100 rounded-full transition-colors text-gray-400">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>
    
    <!-- Content -->
    <div class="p-8 max-h-[60vh] overflow-y-auto space-y-6 text-gray-600 leading-relaxed text-center">
      <div class="space-y-4">
        <p><strong>Responsable:</strong> Asociación de Solidaridad e Integración Sociolaboral de Venezuela (ASISVE).</p>
        <p><strong>Finalidad:</strong> Gestionar tu solicitud de contacto, responder a tus consultas y, si lo autorizas, enviarte información sobre nuestras actividades sociales.</p>
        <p><strong>Legitimación:</strong> Tu consentimiento expreso al marcar la casilla de aceptación.</p>
        <p><strong>Destinatarios:</strong> Tus datos no se cederán a terceros, salvo obligación legal. Se tratan con absoluta confidencialidad.</p>
        <p><strong>Derechos:</strong> Puedes acceder, rectificar y suprimir tus datos enviando un email a <span class="text-primary font-bold">contacto@asisve.org</span>.</p>
      </div>
      <div class="bg-primary/5 p-4 rounded-xl border border-primary/10 mx-auto max-w-md">
        <p class="text-xs font-medium text-dark/70 italic">
          Al cerrar este modal, volverás al formulario. Tus datos no se enviarán hasta que pulses el botón "Enviar mensaje".
        </p>
      </div>
    </div>
    
    <!-- Footer -->
    <div class="p-6 bg-gray-50 border-t border-gray-100 flex justify-center">
      <button type="button" id="closePrivacyBtn" class="bg-primary hover:bg-dark text-white px-10 py-3 rounded-xl font-bold transition-all shadow-lg hover:shadow-primary/20 hover:-translate-y-0.5 active:translate-y-0 min-w-[150px]">
        Entendido
      </button>
    </div>
  </div>
</div>

<style>
</style>

<script>
  import { ApiClient } from '../services/api.client';

  const form = document.querySelector('#contactForm') as HTMLFormElement;
  const statusEl = document.querySelector('#formStatus') as HTMLDivElement;
  const submitBtn = document.querySelector('#formSubmit') as HTMLButtonElement;

  // Modal Logic
  const openModalBtn = document.querySelector('#openPrivacy') as HTMLButtonElement;
  const closeModalBtn = document.querySelector('#closePrivacyBtn') as HTMLButtonElement;
  const closeModalBtnIcon = document.querySelector('#closePrivacyIcon') as HTMLButtonElement;
  const modal = document.querySelector('#privacyModal') as HTMLDivElement;
  const modalContent = document.querySelector('#privacy-modal-content');

  const toggleModal = (show: boolean) => {
    if (show && modal && modalContent) {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
      requestAnimationFrame(() => {
        modal.classList.remove('opacity-0', 'pointer-events-none');
        modal.classList.add('opacity-100');
        modalContent.classList.remove('scale-95');
        modalContent.classList.add('scale-100');
      });
    } else if (modal && modalContent) {
      modal.classList.remove('opacity-100');
      modal.classList.add('opacity-0', 'pointer-events-none');
      modalContent.classList.remove('scale-100');
      modalContent.classList.add('scale-95');
      document.body.style.overflow = '';
      setTimeout(() => {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      }, 300);
    }
  };

  openModalBtn?.addEventListener('click', (e) => {
    e.preventDefault();
    e.stopPropagation();
    toggleModal(true);
  });

  [closeModalBtn, closeModalBtnIcon].forEach(btn => {
    btn?.addEventListener('click', () => toggleModal(false));
  });



  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const dataObj = Object.fromEntries(formData);
    
    // Estado de carga
    submitBtn.disabled = true;
    submitBtn.classList.add('opacity-50', 'pointer-events-none');
    
    statusEl.textContent = 'Procesando tu mensaje...';
    statusEl.className = 'text-center p-5 rounded-2xl font-bold border-2 bg-blue-50/50 border-blue-200 text-blue-600 animate-pulse block scale-100 opacity-100';
    statusEl.classList.remove('hidden');

    // Realizar la petición a nuestra nueva API en PHP
    const result = await ApiClient.post('/contact.php', dataObj);

    // Reset de botón
    submitBtn.disabled = false;
    submitBtn.classList.remove('opacity-50', 'pointer-events-none');

    if (result.success) {
      statusEl.textContent = result.message || '¡Mensaje enviado con éxito!';
      statusEl.className = 'text-center p-5 rounded-2xl font-bold border-2 bg-green-50/50 border-green-200 text-green-700 block scale-100 opacity-100';
      form.reset();
      
      // Ocultar mensaje después de 5 segundos
      setTimeout(() => {
        statusEl.classList.add('opacity-0', 'scale-95');
        setTimeout(() => statusEl.classList.add('hidden'), 500);
      }, 5000);
    } else {
      statusEl.textContent = result.message || 'Error: No se pudo enviar el mensaje.';
      statusEl.className = 'text-center p-5 rounded-2xl font-bold border-2 bg-red-50/50 border-red-200 text-red-700 block scale-100 opacity-100';
    }
  });
</script>

