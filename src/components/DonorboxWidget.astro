---
/**
 * DonorboxWidget Component (Multi-step Version)
 * Uses the modern dbox-widget for better performance and mobile UX.
 */
import { DONORBOX_CONFIG } from "../config/donorbox";

interface Props {
  campaign?: string;
  amount?: string;
  className?: string;
}

const { 
  campaign = DONORBOX_CONFIG.campaignName, 
  amount = "10",
  className = ""
} = Astro.props;
---

<div class:list={["donorbox-widget-wrapper w-full max-w-[500px] mx-auto", className]}>
  <script type="module" src="https://donorbox.org/widgets.js" async></script>
  <dbox-widget 
    campaign={campaign} 
    type="donation_form" 
    amount={amount} 
    enable-auto-scroll="true"
  ></dbox-widget>
</div>

<style is:global>
  /* Fix for Donorbox widget container visibility and spacing */
  dbox-widget {
    display: block;
    min-height: 550px;
    width: 100%;
  }

  /* Optional: Customizing the widget container shadow to match your site */
  .donorbox-widget-wrapper {
    filter: drop-shadow(0 25px 25px rgb(0 0 0 / 0.15));
  }
</style>
