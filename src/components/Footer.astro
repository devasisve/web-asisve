---
import { Mail, MapPin, Phone } from 'lucide-astro';
import { Image } from "astro:assets";
import logoImage from "../assets/logos/Logo_asisve-horizontal.webp";
---

<footer class="bg-primary text-white pt-24 pb-12 border-t border-white/5 relative overflow-hidden">
  {/* Subtle decorative element */}
  <div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2 -z-10"></div>
  
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-16 mb-20">
      <div class="space-y-8">
        <div class="bg-white p-4 rounded-2xl w-52 shadow-lg">
          <Image 
            src={logoImage} 
            alt="ASISVE - Ayuda en acción" 
            class="w-full h-auto" 
          />
        </div>
        <p class="text-white leading-relaxed max-w-sm text-lg font-medium opacity-100">
          Voces de cambio y dignidad. Tu ayuda importa: Súmate a nuestra misión por un mundo más justo y solidario.
        </p>
        <div class="flex gap-5">
          <a
            href="https://www.tiktok.com/@asisve_madrid"
            target="_blank"
            rel="noopener noreferrer"
            class="w-12 h-12 rounded-xl bg-white/10 border border-white/30 flex items-center justify-center hover:bg-white hover:text-primary transition-all group shadow-sm"
            aria-label="TikTok"
          >
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white group-hover:text-primary"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg>
          </a>
          <a
            href="https://www.instagram.com/asisve_madrid/"
            target="_blank"
            rel="noopener noreferrer"
            class="w-12 h-12 rounded-xl bg-white/10 border border-white/30 flex items-center justify-center hover:bg-white hover:text-primary transition-all group shadow-sm"
            aria-label="Instagram"
          >
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" xmlns="http://www.w3.org/2000/svg" class="text-white group-hover:text-primary">
              <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.5"></rect>
              <circle cx="12" cy="12" r="3.5" stroke="currentColor" stroke-width="1.5"></circle>
              <circle cx="17.5" cy="6.5" r="0.75" fill="currentColor"></circle>
            </svg>
          </a>
          <a
            href="https://wa.me/+34644740559/"
            target="_blank"
            rel="noopener noreferrer"
            class="w-12 h-12 rounded-xl bg-white/10 border border-white/30 flex items-center justify-center hover:bg-[#25D366] hover:border-[#25D366] transition-all group shadow-sm"
            aria-label="WhatsApp"
          >
            <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" xmlns="http://www.w3.org/2000/svg" class="text-white group-hover:text-white">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.414 0 .004 5.408 0 12.044c0 2.121.554 4.191 1.604 6.06L0 24l6.095-1.599a11.77 11.77 0 0 0 5.95 1.603h.005c6.635 0 12.046-5.41 12.05-12.047a11.814 11.814 0 0 0-3.593-8.406"></path>
            </svg>
          </a>
        </div>
      </div>

      <div class="space-y-8 lg:pl-12">
        <h4 class="text-xl font-bold text-white relative inline-block">
          Mapa del Sitio
          <span class="absolute -bottom-2 left-0 w-12 h-1 bg-white/40 rounded-full"></span>
        </h4>
        <ul class="space-y-4">
          <li><a href="/" class="text-white hover:translate-x-1 inline-block transition-all duration-300">Inicio</a></li>
          <li><a href="/about" class="text-white hover:translate-x-1 inline-block transition-all duration-300">Sobre Nosotros</a></li>
          <li><a href="/services" class="text-white hover:translate-x-1 inline-block transition-all duration-300">Servicios</a></li>
          <li><a href="/testimonial" class="text-white hover:translate-x-1 inline-block transition-all duration-300">Testimonios</a></li>
          <li><a href="/voluntariado" class="text-white hover:translate-x-1 inline-block transition-all duration-300">Voluntariado</a></li>
          <li><a href="/contact" class="text-white hover:translate-x-1 inline-block transition-all duration-300">Contacto</a></li>
        </ul>
      </div>

      <div class="space-y-8">
        <h4 class="text-xl font-bold text-white relative inline-block">
          Contacto Directo
          <span class="absolute -bottom-2 left-0 w-12 h-1 bg-white/40 rounded-full"></span>
        </h4>
        <ul class="space-y-6">
          <li class="flex gap-4 group">
            <div class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center text-white shrink-0 shadow-inner">
              <MapPin size="24" />
            </div>
            <div class="space-y-1">
              <p class="text-xs text-white font-bold uppercase tracking-widest opacity-80">Ubicación</p>
              <p class="text-white leading-tight font-medium">C. de Fuentelviejo, 37,<br/>San Blas, 28022 Madrid</p>
            </div>
          </li>
          <li class="flex gap-4 group">
            <div class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center text-white shrink-0 shadow-inner">
              <Phone size="24" />
            </div>
            <div class="space-y-1">
              <p class="text-xs text-white font-bold uppercase tracking-widest opacity-80">Llámanos</p>
              <p class="text-white font-medium">+34 644 740 559</p>
            </div>
          </li>
          <li class="flex gap-4 group">
            <div class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center text-white shrink-0 shadow-inner">
              <Mail size="24" />
            </div>
            <div class="space-y-1">
              <p class="text-xs text-white font-bold uppercase tracking-widest opacity-80">Escríbenos</p>
              <p class="text-white italic font-medium">contacto@asisve.org</p>
            </div>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/20 pt-12 flex flex-col md:flex-row justify-between items-center gap-8">
      <p class="text-white text-sm font-medium">
        &copy; {new Date().getFullYear()} <span class="text-white font-black underline decoration-white/30 decoration-2 underline-offset-4">ASISVE</span>. Ayuda en Acción.
      </p>
      <div class="flex gap-10">
        <a href="/privacy" class="text-white text-sm hover:underline transition-all relative group font-bold">
          Política de Privacidad
          <span class="absolute -bottom-1 left-0 w-0 h-px bg-white transition-all duration-300 group-hover:w-full"></span>
        </a>
        <a href="/cookies" class="text-white text-sm hover:underline transition-all relative group font-bold">
          Política de Cookies
          <span class="absolute -bottom-1 left-0 w-0 h-px bg-white transition-all duration-300 group-hover:w-full"></span>
        </a>
      </div>
    </div>
  </div>
</footer>

