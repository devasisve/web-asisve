---
import { Facebook, Instagram, Twitter, Mail, MapPin, Phone } from 'lucide-astro';
---

<footer class="bg-dark text-white pt-16 pb-8">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 mb-12">
      <div class="space-y-6">
        <h3 class="text-2xl font-bold flex items-center gap-2 text-primary">
          ASISVE
        </h3>
        <p class="text-gray-400 leading-relaxed max-w-sm">
          Voces de cambio y dignidad. Tu ayuda importa: Súmate a nuestra misión por un mundo más justo.
        </p>
        <div class="flex gap-4">
          <a href="#" class="w-10 h-10 rounded-full bg-gray-800 flex items-center justify-center hover:bg-primary transition-colors">
            <Facebook size="20" />
          </a>
          <a href="#" class="w-10 h-10 rounded-full bg-gray-800 flex items-center justify-center hover:bg-primary transition-colors">
            <Instagram size="20" />
          </a>
          <a href="#" class="w-10 h-10 rounded-full bg-gray-800 flex items-center justify-center hover:bg-primary transition-colors">
            <Twitter size="20" />
          </a>
        </div>
      </div>

      <div class="space-y-6">
        <h4 class="text-lg font-bold border-b border-primary/30 pb-2 inline-block">Mapa del Sitio</h4>
        <ul class="space-y-4">
          <li><a href="/" class="text-gray-400 hover:text-primary transition-colors">Inicio</a></li>
          <li><a href="/about" class="text-gray-400 hover:text-primary transition-colors">Sobre Nosotros</a></li>
          <li><a href="/services" class="text-gray-400 hover:text-primary transition-colors">Servicios</a></li>
          <li><a href="/testimonial" class="text-gray-400 hover:text-primary transition-colors">Testimonios</a></li>
          <li><a href="/contact" class="text-gray-400 hover:text-primary transition-colors">Contacto</a></li>
        </ul>

      </div>

      <div class="space-y-6">
        <h4 class="text-lg font-bold border-b border-primary/30 pb-2 inline-block">Contacto</h4>
        <ul class="space-y-4">
          <li class="flex gap-3 text-gray-400 items-start">
            <MapPin size="20" class="text-primary shrink-0" />
            <span>C. de Fuentelviejo, 37, San Blas, 28022 Madrid</span>
          </li>
          <li class="flex gap-3 text-gray-400 items-center">
            <Phone size="20" class="text-primary shrink-0" />
            <span>+34 644 740 559</span>
          </li>
          <li class="flex gap-3 text-gray-400 items-center">
            <Mail size="20" class="text-primary shrink-0" />
            <span>contacto@asisve.org</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-gray-500 text-sm">
      <p>&copy; {new Date().getFullYear()} ASISVE. Todos los derechos reservados.</p>
      <div class="flex gap-6">
        <a href="/privacy" class="hover:text-primary transition-colors">Política de Privacidad</a>
        <a href="/cookies" class="hover:text-primary transition-colors">Política de Cookies</a>
      </div>
    </div>
  </div>
</footer>

