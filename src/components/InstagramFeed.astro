---
import { InstagramService } from "../services/instagram.service";
import InstagramPostCard from "./InstagramPostCard.astro";

// Pre-fetch data on the server to avoid CORS issues on the client
// We fetch 6 to ensure we have enough after filtering for Reels/Videos if needed, 
// though the service now handles the 3 most recent.
const { posts: initialPosts } = await InstagramService.getFeed(3, true);
---

<section class="py-24 bg-dark relative overflow-hidden" id="instagram-section">
  <!-- Decorative Background -->
  <div class="absolute top-0 left-1/4 w-96 h-96 bg-primary/10 rounded-full blur-[120px] -z-10"></div>
  <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-primary/5 rounded-full blur-[120px] -z-10"></div>

  <div class="container mx-auto px-4">
    <header class="flex flex-col md:flex-row justify-between items-end gap-8 mb-16">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/20 border border-primary/30 text-primary-light text-xs font-bold uppercase tracking-widest mb-4">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
          </span>
          En vivo desde Instagram
        </div>
        <h2 class="text-4xl md:text-6xl font-black text-white tracking-tighter leading-tight">
          Nuestra labor en <span class="text-primary-light italic">tiempo real</span>
        </h2>
      </div>
      
      <a 
        href="https://www.instagram.com/asisve_/" 
        target="_blank" 
        class="group flex items-center gap-4 bg-white/5 hover:bg-white/10 border border-white/10 px-8 py-4 rounded-2xl transition-all"
      >
        <span class="text-white font-bold">Seguir en Instagram</span>
        <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center text-white group-hover:rotate-12 transition-transform">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-instagram"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
        </div>
      </a>
    </header>

    <!-- Posts Grid -->
    <div 
      id="instagram-posts-container" 
      class="grid grid-cols-1 md:grid-cols-3 gap-8 min-h-[400px]"
    >
      {initialPosts.map((post) => (
        <InstagramPostCard post={post} />
      ))}
    </div>
  </div>
</section>
