---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  subtitle: string;
  description: string;
  icon: any;
  image: string | ImageMetadata;
  delay?: string;
}

const { title, subtitle, description, icon: Icon, image, delay = "0" } = Astro.props;

// Detect if image is likely a logo to use object-contain instead of cover
const isLogo = typeof image === 'string' 
  ? image.toLowerCase().includes('logo')
  : (image as any).src.toLowerCase().includes('logo');
---

<div 
  class="group bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-500 hover:-translate-y-2 border border-gray-100"
  style={`animation-delay: ${delay}ms`}
>
  <div class={`h-48 w-full overflow-hidden relative flex items-center justify-center ${isLogo ? 'bg-gray-50 p-6' : ''}`}>
    <Image 
      src={image as any} 
      alt={title} 
      width={600}
      height={400}
      class={`w-full h-full transition-transform duration-700 group-hover:scale-110 object-cover`}
    />
    <div class="absolute inset-0 bg-linear-to-t from-dark/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
  </div>
  
  <div class="p-6 relative">
    <div class="absolute -top-10 right-6 w-14 h-14 bg-primary text-white rounded-xl flex items-center justify-center shadow-lg transform transition-transform group-hover:rotate-12 group-hover:scale-110">
      <Icon size="28" />
    </div>
    
    <h3 class="text-xl font-bold text-dark mb-3 group-hover:text-primary transition-colors">
      {title}
    </h3>
    <h4 class="text-gray-800 text-sm leading-relaxed mb-3">
      {subtitle}
    </h4>
    <p class="text-gray-800 text-sm leading-relaxed">
      {description}
    </p>
  </div>
</div>
