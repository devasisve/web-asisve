---
import { Image } from "astro:assets";

interface Sponsor {
  name: string;
  logoPath: string;
}

const images = import.meta.glob<{ default: ImageMetadata }>('../assets/img/*.{png,webp,jpg,jpeg}', { eager: true });

const sponsors: Sponsor[] = [
  { name: "Banco de Alimentos", logoPath: "../assets/img/banco-alimentos.png" },
  { name: "Shukran", logoPath: "../assets/img/logo-shukran.png" },
  { name: "Amazon", logoPath: "../assets/img/amazon.png" },
  { name: "Altius", logoPath: "../assets/img/logo-altius.png" },
  { name: "Diaconía", logoPath: "../assets/img/logo-diaconia.png" },
  { name: "Remar", logoPath: "../assets/img/logo-remar.png" },
  { name: "Alcamar", logoPath: "../assets/img/logo-alcamar.webp" },
  { name: "AMA", logoPath: "../assets/img/logo-ama.jpg" },
  { name: "Frioval", logoPath: "../assets/img/frioval.jpg" },
  { name: "Comunidad de Madrid", logoPath: "../assets/img/logo-madrid.webp" },
];

// Duplicate sponsors for infinite effect
const allSponsors = [...sponsors, ...sponsors];
---

<section class="py-20 bg-white overflow-hidden">
  <div class="container mx-auto px-4 mb-12">
    <div class="max-w-2xl">
      <h2 class="text-primary font-bold tracking-widest uppercase text-sm mb-2">Empresas Increíbles</h2>
      <h3 class="text-4xl md:text-5xl font-extrabold text-dark leading-tight">Nuestros Colaboradores</h3>
      <div class="w-16 h-1 bg-primary mt-4"></div>
    </div>
  </div>

  <div class="relative flex overflow-x-hidden group max-w-[1480px] mx-auto">
    <div class="animate-scroll flex gap-8 py-4 whitespace-nowrap min-w-full">
      {allSponsors.map((sponsor) => {
        const logo = images[sponsor.logoPath]?.default;
        return (
          <div class="flex shrink-0 w-64 h-32 items-center justify-center p-6 bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-all duration-300 grayscale hover:grayscale-0">
            {logo ? (
              <Image 
                src={logo} 
                alt={`Logo de ${sponsor.name}`} 
                width={200}
                height={100}
                class="max-w-full max-h-full object-contain"
                loading="lazy"
              />
            ) : (
              <span class="text-gray-300 font-bold">{sponsor.name}</span>
            )}
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .animate-scroll {
    display: flex;
    width: max-content;
    animation: scroll 10s linear infinite;
  }

  .group:hover .animate-scroll {
    animation-play-state: paused;
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  /* Optional: smoothing for different screen sizes */
  @media (max-width: 768px) {
    .animate-scroll {
      padding-inline: 2rem;
      animation-duration: 15s;
    }
  }
</style>
