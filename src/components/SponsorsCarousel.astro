---
import { Image } from "astro:assets";

interface Sponsor {
  name: string;
  logo: ImageMetadata;
}

interface Props {
  sponsors: Sponsor[];
  title?: string;
  subtitle?: string;
}

const { 
  sponsors = [],
  title = "Nuestros Colaboradores",
  subtitle = "Empresas Increíbles"
} = Astro.props;

// Duplicamos el array para el efecto de scroll infinito
const allSponsors = [...sponsors, ...sponsors];
---

<section class="py-20 bg-white overflow-hidden">
  <div class="container mx-auto px-4 mb-12">
    <div class="max-w-2xl">
      {subtitle && <h2 class="text-primary font-bold tracking-widest uppercase text-sm mb-2">{subtitle}</h2>}
      {title && <h3 class="text-4xl md:text-5xl font-extrabold text-dark leading-tight">{title}</h3>}
      <div class="w-16 h-1 bg-primary mt-4"></div>
    </div>
  </div>

  <div class="relative flex overflow-x-hidden group max-w-[1480px] mx-auto">
    <div class="animate-scroll flex gap-8 py-4 whitespace-nowrap min-w-full">
      {allSponsors.map((sponsor) => (
        <div class="flex shrink-0 w-64 h-32 items-center justify-center p-6 bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-all duration-300 grayscale hover:grayscale-0">
          <Image 
            src={sponsor.logo} 
            alt={`Logo de ${sponsor.name}`} 
            width={200}
            height={100}
            class="max-w-full max-h-full object-contain"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .animate-scroll {
    display: flex;
    width: max-content;
    animation: scroll 30s linear infinite; /* Aumentado a 30s para un scroll más suave con muchos logos */
  }

  .group:hover .animate-scroll {
    animation-play-state: paused;
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 768px) {
    .animate-scroll {
      animation-duration: 20s;
    }
  }
</style>
