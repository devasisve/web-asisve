---
import { Image } from "astro:assets";
import Layout from '../layouts/Layout.astro';
import combinedLogo from "../assets/about/qs01.webp";
import vision1 from "../assets/about/qs02.webp";
import vision2 from "../assets/about/qs03.webp";
import premioImg from "../assets/about/premio.jpeg";
---

<Layout title="Sobre Nosotros | ASISVE">
  <section class="py-24 bg-white overflow-hidden">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        {/* Intro Section */}
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center mb-24">
          <div class="space-y-8 animate-fade-in-up">
            <h2 class="text-primary font-bold tracking-widest uppercase text-sm">Nuestra Identidad</h2>
            <h1 class="text-5xl md:text-6xl font-extrabold text-dark leading-tight">
              Dignidad y esperanza para el <span class="text-primary italic">migrante</span>
            </h1>
            <p class="text-lg text-gray-800 leading-relaxed font-medium">
              ASISVE nació como un faro de solidaridad en Madrid, con la firme convicción de que nadie debería enfrentar la migración en soledad o precariedad. Somos una comunidad que tiende puentes hacia la integración real.
            </p>
          </div>
          <div class="relative animate-fade-in-up w-full aspect-video" style="animation-delay: 200ms">
           <iframe 
              width="560" 
              height="315" 
              src="https://www.youtube.com/embed/SioW0_Rve0s?si=Ifb9sdkG0lrIR6hF" 
              title="YouTube video player" 
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
              referrerpolicy="strict-origin-when-cross-origin" 
              allowfullscreen
              class="w-full h-full rounded-3xl"
              >
            </iframe>
          </div>
        </div>

        {/* Sections: Objetivo, Visión y Misión */}
        <div class="space-y-24 mb-32">
          {/* Nuestro Objetivo */}
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-center">
            <div class="flex justify-center reveal-left">
              <div class="w-full max-w-sm md:max-w-lg lg:max-w-none">
                <Image 
                  src={combinedLogo} 
                  alt="Personal de ASISVE colaborando" 
                  class="w-full aspect-4/3 object-cover rounded-3xl shadow-xl cursor-zoom-in hover:scale-[1.02] transition-transform duration-300 zoomable-image" 
                />
              </div>
            </div>
            <div class="space-y-4 md:space-y-6 border-l-4 border-primary pl-6 md:pl-10 reveal-right" style="animation-delay: 300ms">
              <h2 class="text-2xl md:text-3xl font-bold text-dark tracking-tight">Nuestro Objetivo</h2>
              <p class="text-gray-600 text-sm md:text-base leading-relaxed max-w-xl">
                Nuestro objetivo es ser el pilar de apoyo integral para los migrantes de Iberoamérica en Madrid. Queremos ofrecer un espacio de acogida y apoyo continuo que permita a los migrantes encontrar una nueva oportunidad de vida, con el respaldo necesario para que puedan reintegrarse en la sociedad, accediendo a recursos educativos, asistencia social y oportunidades laborales. Apostamos por el empoderamiento de cada individuo, promoviendo su bienestar y ayudando a que sus sueños se hagan realidad.
              </p>
            </div>
          </div>

          {/* Nuestra Visión */}
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-center">
            <div class="flex justify-center reveal-left">
              <div class="w-full max-w-sm md:max-w-lg lg:max-w-none">
                <Image 
                  src={vision1} 
                  alt="Nuestra Visión" 
                  class="w-full aspect-4/3 object-cover rounded-3xl shadow-xl cursor-zoom-in hover:scale-[1.02] transition-transform duration-300 zoomable-image" 
                />
              </div>
            </div>
            <div class="space-y-4 md:space-y-6 border-l-4 border-primary pl-6 md:pl-10 reveal-right" style="animation-delay: 300ms">
              <h2 class="text-2xl md:text-3xl font-bold text-dark tracking-tight">Nuestra Visión</h2>
              <p class="text-gray-600 text-sm md:text-base leading-relaxed max-w-xl">
                Nos visualizamos como una comunidad inclusiva y acogedora que se compromete a empoderar a los migrantes de Iberoamérica en Madrid. Buscamos ser reconocidos como un centro de recursos integrales, donde cada persona pueda encontrar el apoyo necesario para su integración y desarrollo personal. Aspiramos a construir puentes de entendimiento y colaboración entre diferentes culturas, promoviendo la diversidad y la igualdad de oportunidades en nuestra sociedad. Trabajamos hacia un futuro donde todos los migrantes se sientan incluidos, valorados, respetados y capaces de alcanzar su máximo potencial en un entorno de equidad y justicia.
              </p>
            </div>
          </div>

          {/* Nuestra Misión */}
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-center">
            <div class="flex justify-center reveal-left">
              <div class="w-full max-w-sm md:max-w-lg lg:max-w-none">
                <Image 
                  src={vision2} 
                  alt="Nuestra Misión" 
                  class="w-full aspect-4/3 object-cover rounded-3xl shadow-xl cursor-zoom-in hover:scale-[1.02] transition-transform duration-300 zoomable-image" 
                />
              </div>
            </div>
            <div class="space-y-4 md:space-y-6 border-l-4 border-primary pl-6 md:pl-10 reveal-right" style="animation-delay: 300ms">
              <h2 class="text-2xl md:text-3xl font-bold text-dark tracking-tight">Nuestra Misión</h2>
              <p class="text-gray-600 text-sm md:text-base leading-relaxed max-w-xl">
                Nuestra misión es brindar apoyo integral a los migrantes de Iberoamérica en Madrid, ofreciendo cestas de alimentos nutritivos semanalmente, ropa adecuada, refugio temporal seguro, consultas médicas y cursos de formación. Nos esforzamos por ser un faro de esperanza y solidarity, proporcionando asistencia humanitaria y promoviendo la dignidad y el bienestar de cada individuo que llega a nuestras puertas, trabajando de manera colaborativa con diversas organizaciones y entidades para proporcionar soluciones sostenibles y holísticas que aborden las necesidades inmediatas y a largo plazo de esta comunidad.
              </p>
            </div>
          </div>
        </div>
        
        {/* Award Section */}
        <div class="bg-primary text-white py-10 md:py-14 px-8 md:px-12 rounded-[2.5rem] mb-24 shadow-xl">
          <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-8 md:gap-12">
            <div class="w-32 h-32 md:w-36 md:h-36 bg-white rounded-full flex items-center justify-center shrink-0 shadow-lg border-4 border-white/20 overflow-hidden cursor-zoom-in hover:scale-110 transition-transform duration-300 zoomable-image">
              <Image src={premioImg} alt="Certificado Premio Excelencia Hispana" class="w-full h-full object-contain p-2" />
            </div>
            <div class="text-center md:text-left space-y-4">
              <h3 class="text-2xl md:text-3xl font-bold uppercase tracking-widest text-white/95">Orgullosamente premiados</h3>
              <p class="text-lg md:text-xl font-medium leading-relaxed italic text-white/90">
                "Ganadores a la <strong>“EXCELENCIA HISPANA 2025"</strong>, en la categoría Asociación Civil Hispana” por la Cámara de Empresarios Venezolanos en España, CeVe.
              </p>
            </div>
          </div>
        </div>

        {/* Stats Section */}
        <h2 class="text-4xl lg:text-5xl font-bold text-dark text-center">Nuestro impacto en la comunidad</h2>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mt-10 text-center">
          <div class="flex flex-col p-6 gap-4">
            <div class="text-5xl font-extrabold text-primary stat-number" data-target="14293">0</div>
            <div class="text-gray-800 font-bold uppercase tracking-wide">Familias Beneficiadas</div>
          </div>
          <div class="flex flex-col p-6 gap-4">
            <div class="text-5xl font-extrabold text-primary stat-number" data-target="692">0</div>
            <div class="text-gray-800 font-bold uppercase tracking-wide">Personas en Refugio</div>
          </div>
          <div class="flex flex-col p-6 gap-4">
            <div class="text-5xl font-extrabold text-primary stat-number" data-target="684970">0</div>
            <div class="text-gray-800 font-bold uppercase tracking-wide">Kilos de Alimentos</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Lightbox Modal */}
  <div id="image-modal" class="fixed inset-0 z-50 bg-black/90 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300 backdrop-blur-sm">
    <button id="close-modal" class="absolute top-6 right-6 text-white hover:text-primary transition-colors focus:outline-none" aria-label="Cerrar">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <div class="max-w-5xl max-h-[90vh] p-4 flex items-center justify-center">
      <img id="modal-img" src="" alt="" class="max-w-full max-h-full object-contain rounded-lg shadow-2xl scale-95 transition-transform duration-300" />
    </div>
  </div>
</Layout>

<script>
  const animateStats = () => {
    const stats = document.querySelectorAll('.stat-number');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const target = parseInt(el.getAttribute('data-target') || '0');
          const suffix = el.getAttribute('data-suffix') || '';
          const duration = 2000; // 2 seconds
          const startTime = performance.now();
          
          const updateCount = (currentTime: number) => {
            const elapsedTime = currentTime - startTime;
            const progress = Math.min(elapsedTime / duration, 1);
            
            // Easing function: easeOutExpo
            const easeProgress = progress === 1 ? 1 : 1 - Math.pow(2, -10 * progress);
            const currentCount = Math.floor(easeProgress * target);
            
            el.textContent = currentCount.toLocaleString('es-ES') + suffix;
            
            if (progress < 1) {
              requestAnimationFrame(updateCount);
            }
          };
          
          requestAnimationFrame(updateCount);
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.5 });
    
    stats.forEach(stat => observer.observe(stat));
  };

  const setupRevealAnimations = () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          if (entry.target.classList.contains('reveal-left')) {
            entry.target.classList.add('animate-left');
          } else if (entry.target.classList.contains('reveal-right')) {
            entry.target.classList.add('animate-right');
          }
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal-left, .reveal-right').forEach(el => observer.observe(el));
  };

  const setupImageZoom = () => {
    const modal = document.getElementById('image-modal');
    const modalImg = document.getElementById('modal-img') as HTMLImageElement;
    const closeModal = document.getElementById('close-modal');
    const zoomableImages = document.querySelectorAll('.zoomable-image');

    const openModal = (imgSrc: string, alt: string) => {
      if (!modal || !modalImg) return;
      modalImg.src = imgSrc;
      modalImg.alt = alt;
      modal.classList.remove('opacity-0', 'pointer-events-none');
      document.body.style.overflow = 'hidden';
      
      // Trigger zoom animation
      setTimeout(() => {
        modalImg.classList.remove('scale-95');
        modalImg.classList.add('scale-100');
      }, 10);
    };

    const closeImageModal = () => {
      if (!modal || !modalImg) return;
      modal.classList.add('opacity-0', 'pointer-events-none');
      modalImg.classList.remove('scale-100');
      modalImg.classList.add('scale-95');
      document.body.style.overflow = '';
      
      // Clean up src after animation
      setTimeout(() => {
        modalImg.src = '';
      }, 300);
    };

    zoomableImages.forEach(container => {
      container.addEventListener('click', () => {
        const img = container.tagName === 'IMG' ? container as HTMLImageElement : container.querySelector('img');
        if (img) {
          openModal(img.src, img.alt);
        }
      });
    });

    closeModal?.addEventListener('click', closeImageModal);
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) closeImageModal();
    });

    // Close on escape
    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeImageModal();
    });
  };

  // Run on load and after view transitions
  animateStats();
  setupRevealAnimations();
  setupImageZoom();

  document.addEventListener('astro:after-swap', () => {
    animateStats();
    setupRevealAnimations();
    setupImageZoom();
  });
</script>

<style>
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .animate-fade-in-up {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }

  @keyframes fadeInLeft {
    from { opacity: 0; transform: translateX(-100px); }
    to { opacity: 1; transform: translateX(0); }
  }

  @keyframes fadeInRight {
    from { opacity: 0; transform: translateX(100px); }
    to { opacity: 1; transform: translateX(0); }
  }

  .reveal-left, .reveal-right {
    opacity: 0;
  }

  .animate-left {
    animation: fadeInLeft 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .animate-right {
    animation: fadeInRight 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>
