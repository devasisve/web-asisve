---
import { Image } from "astro:assets";
import Layout from '../layouts/Layout.astro';
import { Eye, Rocket, Users, HandHeart, Globe } from 'lucide-astro';
import combinedLogo from "../assets/img/combined_logo.png";
import vision1 from "../assets/img/vision.jpg";
import vision2 from "../assets/img/vision-2.jpg";
---

<Layout title="Sobre Nosotros | ASISVE">
  <section class="py-24 bg-white overflow-hidden">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        {/* Intro Section */}
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center mb-24">
          <div class="space-y-8 animate-fade-in-up">
            <h2 class="text-primary font-bold tracking-widest uppercase text-sm">Nuestra Identidad</h2>
            <h1 class="text-5xl md:text-6xl font-extrabold text-dark leading-tight">
              Dignidad y esperanza para el <span class="text-primary italic">migrante</span>
            </h1>
            <p class="text-lg text-gray-800 leading-relaxed font-medium">
              ASISVE nació como un faro de solidaridad en Madrid, con la firme convicción de que nadie debería enfrentar la migración en soledad o precariedad. Somos una comunidad que tiende puentes hacia la integración real.
            </p>
          </div>
          <div class="relative animate-fade-in-up" style="animation-delay: 200ms">
            <div class="absolute -top-6 -left-6 w-full h-full border-2 border-primary/10 rounded-3xl -z-10 translate-x-4 translate-y-4"></div>
            <Image 
              src={combinedLogo} 
              alt="ASISVE Logo" 
              class="w-full h-auto rounded-3xl shadow-2xl bg-white p-12"
            />
          </div>
        </div>

        {/* Vision & Mission Grid */}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-32">
          <div class="bg-gray-50 p-10 rounded-3xl space-y-6 hover:shadow-xl transition-shadow border border-gray-100 group">
            <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-all">
              <Eye size="32" />
            </div>
            <h3 class="text-3xl font-bold text-dark">Nuestra Visión</h3>
            <p class="text-gray-800 leading-relaxed font-medium">
              Buscamos ser reconocidos como el centro de referencia integral en Madrid, donde cada migrante iberoamericano encuentre las herramientas para su desarrollo pleno en una sociedad equitativa y justa.
            </p>
          </div>

          <div class="bg-gray-50 p-10 rounded-3xl space-y-6 hover:shadow-xl transition-shadow border border-gray-100 group">
            <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-all">
              <Rocket size="32" />
            </div>
            <h3 class="text-3xl font-bold text-dark">Nuestra Misión</h3>
            <p class="text-gray-800 leading-relaxed font-medium">
              Brindamos soporte vital inmediato: alimentación, refugio, atención médica y formación. Trabajamos para transformar la asistencia en empoderamiento y soluciones de vida sostenibles.
            </p>
          </div>
        </div>

        {/* Strategy Section */}
        <div class="bg-dark rounded-[40px] p-8 md:p-16 text-white relative overflow-hidden">
          <div class="absolute top-0 right-0 w-64 h-64 bg-primary/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
          
          <div class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div class="space-y-6">
              <h2 class="text-3xl font-bold">Nuestro Objetivo Estratégico</h2>
              <p class="text-white text-lg leading-relaxed font-medium">
                Ser el pilar de apoyo continuo que permita a los migrantes reintegrarse plenamente, facilitando el acceso a recursos educativos, laborales y sociales esenciales para alcanzar sus sueños.
              </p>
              <div class="flex flex-wrap gap-4 pt-4">
                <div class="flex items-center gap-2 text-sm text-white font-bold py-2.5 px-5 bg-primary/20 rounded-full border border-primary-light/30 backdrop-blur-sm transition-all hover:bg-primary/30">
                  <HandHeart size="18" class="text-primary-light" /> Solidaridad
                </div>
                <div class="flex items-center gap-2 text-sm text-white font-bold py-2.5 px-5 bg-primary/20 rounded-full border border-primary-light/30 backdrop-blur-sm transition-all hover:bg-primary/30">
                  <Globe size="18" class="text-primary-light" /> Integración
                </div>
                <div class="flex items-center gap-2 text-sm text-white font-bold py-2.5 px-5 bg-primary/20 rounded-full border border-primary-light/30 backdrop-blur-sm transition-all hover:bg-primary/30">
                  <Users size="18" class="text-primary-light" /> Comunidad
                </div>
              </div>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <Image src={vision1} alt="Impacto" class="rounded-2xl aspect-square object-cover shadow-lg translate-y-8" />
              <Image src={vision2} alt="Comunidad" class="rounded-2xl aspect-square object-cover shadow-lg" />
            </div>
          </div>
        </div>

        {/* Stats Section */}
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mt-24 text-center">
          <div class="p-8">
            <div class="text-5xl font-extrabold text-primary mb-2 stat-number" data-target="8334">0</div>
            <div class="text-gray-800 font-bold uppercase tracking-wide">Familias Beneficiadas</div>
          </div>
          <div class="p-8">
            <div class="text-5xl font-extrabold text-primary mb-2 stat-number" data-target="505">0</div>
            <div class="text-gray-800 font-bold uppercase tracking-wide">Personas en Refugio</div>
          </div>
          <div class="p-8">
            <div class="text-5xl font-extrabold text-primary mb-2 stat-number" data-target="414" data-suffix="k+">0</div>
            <div class="text-gray-800 font-bold uppercase tracking-wide">Kilos de Alimentos</div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const animateStats = () => {
    const stats = document.querySelectorAll('.stat-number');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const target = parseInt(el.getAttribute('data-target') || '0');
          const suffix = el.getAttribute('data-suffix') || '';
          const duration = 2000; // 2 seconds
          const startTime = performance.now();
          
          const updateCount = (currentTime: number) => {
            const elapsedTime = currentTime - startTime;
            const progress = Math.min(elapsedTime / duration, 1);
            
            // Easing function: easeOutExpo
            const easeProgress = progress === 1 ? 1 : 1 - Math.pow(2, -10 * progress);
            const currentCount = Math.floor(easeProgress * target);
            
            el.textContent = currentCount.toLocaleString('es-ES') + suffix;
            
            if (progress < 1) {
              requestAnimationFrame(updateCount);
            }
          };
          
          requestAnimationFrame(updateCount);
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.5 });
    
    stats.forEach(stat => observer.observe(stat));
  };

  // Run on load and after view transitions
  animateStats();
  document.addEventListener('astro:after-swap', animateStats);
</script>

<style>
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .animate-fade-in-up {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }
</style>
