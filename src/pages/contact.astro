---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import { Mail, Phone, MapPin } from 'lucide-react';
---

<Layout title="ASISVE | Contacto">
  <section class="py-24 bg-gray-50 bg-gradient-to-b from-white to-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
          
          <div class="space-y-12">
            <div class="space-y-4">
              <h2 class="text-primary font-bold tracking-widest uppercase text-sm">Ponte en contacto</h2>
              <h1 class="text-5xl font-extrabold text-dark leading-tight">Queremos escucharte</h1>
              <p class="text-gray-500 text-lg leading-relaxed">
                Ya sea para colaborar, solicitar ayuda o simplemente preguntar, nuestro equipo está aquí para apoyarte.
              </p>
            </div>

            <div class="grid grid-cols-1 gap-8">
              <div class="flex gap-6 items-start group">
                <div class="w-14 h-14 bg-white rounded-2xl shadow-md flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-all">
                  <Mail size={24} />
                </div>
                <div>
                  <h4 class="text-lg font-bold text-dark">Correo Electrónico</h4>
                  <p class="text-gray-500">contacto@asisve.org</p>
                </div>
              </div>

              <div class="flex gap-6 items-start group">
                <div class="w-14 h-14 bg-white rounded-2xl shadow-md flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-all">
                  <Phone size={24} />
                </div>
                <div>
                  <h4 class="text-lg font-bold text-dark">Teléfono / WhatsApp</h4>
                  <p class="text-gray-500">+34 644 740 559</p>
                </div>
              </div>

              <div class="flex gap-6 items-start group">
                <div class="w-14 h-14 bg-white rounded-2xl shadow-md flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-all">
                  <MapPin size={24} />
                </div>
                <div>
                  <h4 class="text-lg font-bold text-dark">Ubicación</h4>
                  <p class="text-gray-500">C. de Fuentelviejo, 37, 28022 Madrid</p>
                </div>
              </div>
            </div>
          </div>

          <div class="relative">
            <div class="absolute -top-10 -right-10 w-40 h-40 bg-primary/10 rounded-full blur-3xl"></div>
            <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-secondary/10 rounded-full blur-3xl"></div>
            <ContactForm />
          </div>

        </div>
      </div>
    </div>
  </section>
</Layout>
