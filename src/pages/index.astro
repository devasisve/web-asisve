---
import Layout from "../layouts/Layout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import SponsorsCarousel from "../components/SponsorsCarousel.astro";
import InstagramFeed from "../components/InstagramFeed.astro";
import Location from "../components/Location.astro";
import { Apple, Home, Activity, Users, Shirt, ArrowRight } from "lucide-astro";

const services = [
  {
    title: "Jornada Alimentos",
    description:
      "Proveemos alimentos esenciales a familias migrantes en situación de vulnerabilidad. Cada semana, distribuimos cestas que incluyen productos básicos.",
    icon: Apple,
    image: "/img/entrega_alimentos.JPG",
  },
  {
    title: "Refugio Temporal",
    description:
      "Ofrecemos un lugar seguro para personas en riesgo, proporcionando un techo temporal. Un espacio de esperanza y protección.",
    icon: Home,
    image: "/img/refugio.jpg",
  },
  {
    title: "Jornada Médica",
    description:
      "Brindamos jornadas de salud y recibimos donaciones de medicamentos entregados de manera segura por personal especializado.",
    icon: Activity,
    image: "/img/jornada_medica.JPG",
  },
  {
    title: "Voluntariado",
    description:
      "Ser voluntario es más que donar tiempo; es una experiencia que fortalece habilidades y genera un impacto positivo en la sociedad.",
    icon: Users,
    image: "/img/voluntariado.JPG",
  },
  {
    title: "Ropero Solidario",
    description:
      "Contamos con prendas para toda la familia, asegurando que cada persona reciba lo necesario para su día a día.",
    icon: Shirt,
    image: "/img/ropero.jpg",
  },
];
---

<Layout title="ASISVE | Ayuda en acción">
  {/* Hero Section */}
  <section class="relative h-[85vh] flex items-center overflow-hidden bg-dark">
    <div class="absolute inset-0 z-0">
      <img
        src="/img/carrusel 1.webp"
        class="w-full h-full object-cover opacity-40 scale-105 animate-slow-zoom"
        alt="Hero Background"
      />
      <div
        class="absolute inset-0 bg-gradient-to-r from-dark via-dark/80 to-transparent"
      >
      </div>
    </div>

    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-3xl space-y-8">
        <div
          class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-sm font-semibold animate-fade-in-up"
        >
          <span class="relative flex h-2 w-2">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"
            ></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"
            ></span>
          </span>
          Voces de cambio y dignidad
        </div>

        <h1
          class="text-6xl md:text-8xl text-white font-bold leading-tight animate-fade-in-up"
          style="animation-delay: 200ms"
        >
          ASISVE <br />
          <span class="text-primary italic">Ayuda en acción</span>
        </h1>

        <p
          class="text-xl text-gray-300 leading-relaxed max-w-xl animate-fade-in-up"
          style="animation-delay: 400ms"
        >
          Nuestra misión es transformar vidas a través de la solidaridad y el
          compromiso social. Súmate como voluntario o colaborador.
        </p>

        <div
          class="flex flex-wrap gap-4 pt-4 animate-fade-in-up"
          style="animation-delay: 600ms"
        >
          <a
            href="/contact"
            class="bg-primary hover:bg-white hover:text-dark text-white px-8 py-4 rounded-full font-bold text-lg transition-all shadow-xl hover:shadow-primary/20 flex items-center gap-2 group"
          >
            Quiero ser voluntario
            <ArrowRight
              class="transition-transform group-hover:translate-x-1"
            />
          </a>
          <a
            href="/testimonial"
            class="border-2 border-white/20 hover:border-white text-white px-8 py-4 rounded-full font-bold text-lg transition-all backdrop-blur-sm"
          >
            Ver testimonios
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* Services Section */}
  <section class="py-24 bg-gray-50">
    <div class="container mx-auto px-4">
      <div
        class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6"
      >
        <div class="max-w-2xl space-y-4">
          <h2 class="text-primary font-bold tracking-widest uppercase text-sm">
            Nuestra Labor
          </h2>
          <h3
            class="text-4xl md:text-5xl font-extrabold text-dark leading-tight"
          >
            Servicios de ASISVE
          </h3>
          <div class="w-20 h-1.5 bg-primary rounded-full"></div>
        </div>
        <p class="text-gray-500 max-w-md font-medium">
          Damos soporte integral a personas en riesgo de exclusión social,
          cubriendo desde necesidades básicas hasta integración laboral.
        </p>
      </div>

      <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-6"
      >
        {
          services.map((service, index) => (
            <ServiceCard {...service} delay={(index * 150).toString()} />
          ))
        }
      </div>
    </div>
  </section>

  {/* Sponsors Carousel Section */}
  <SponsorsCarousel />

  {/* Instagram Feed Section */}
  <InstagramFeed />

  {/* Location Section */}
  <Location />
</Layout>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slowZoom {
    from {
      transform: scale(1.05);
    }
    to {
      transform: scale(1.15);
    }
  }

  .animate-fade-in-up {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }

  .animate-slow-zoom {
    animation: slowZoom 20s ease-in-out infinite alternate;
  }
</style>
