---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import SponsorsCarousel from "../components/SponsorsCarousel.astro";
import InstagramFeed from "../components/InstagramFeed.astro";
import Location from "../components/Location.astro";
import { Apple, Home, Activity, Shirt, ArrowRight, Scale, Beef } from "lucide-astro";

// Hero Image
import heroImage from "../assets/img/hero-inicio.webp";

// Service Images
import serviceAlimentos from "../assets/services/alimentos.webp";
import serviceRefugio from "../assets/services/refugio.webp";
import serviceMedica from "../assets/services/recetas.medicina.webp";
import serviceLegal from "../assets/services/asesorialegal.webp";
import serviceRopero from "../assets/services/ropero.webp";
import serviceBanco from "../assets/services/bancodealimentos.webp";

const services = [
  {
    title: "Jornada de alimentos",
    subtitle: "Sábados · 11:00 am · Registro con documento",
    description:
      "Proveemos alimentos esenciales a familias migrantes en situación de vulnerabilidad. Cada semana, distribuimos cestas que incluyen productos básicos para garantizar una alimentación balanceada y contribuir al bienestar de quienes más lo necesitan.",
    icon: Apple,
    image: serviceAlimentos,
  },
  {
    title: "Casa de Acogida",
    subtitle: "Plazas limitadas · Evaluación de urgencia",
    description:
      "Ofrecemos un lugar seguro para personas en riesgo, proporcionando un techo temporal. Nuestro refugio busca ser más que un espacio físico: es un lugar de esperanza, donde quienes enfrentan situaciones críticas pueden sentirse acogidos y protegidos.",
    icon: Home,
    image: serviceRefugio,
  },
  {
    title: "Entrega de medicamentos",
    subtitle: "Con receta médica · Turnos programados",
    description:
      "En nuestra organización, también brindamos jornadas de salud. Además, recibimos donaciones de medicamentos, los cuales son entregados de manera segura y responsable por nuestro personal especializado, siempre bajo receta médica.",
    icon: Activity,
    image: serviceMedica,
  },
  {
    title: "Asesoría Legal Gratuita",
    subtitle: "Migración · Arraigo · Consultas",
    description: "Orientación en trámites de extranjería, derechos laborales y regularización para facilitar la estancia legal.",
    icon: Scale,
    image: serviceLegal,
  },
  {
    title: "Ropero Solidario",
    subtitle: "Ropa de temporada · Según stock",
    description:
      "Contamos con prendas para toda la familia: desde abrigos para el invierno hasta ropa ligera para el verano, así como calzado y accesorios. A través de donaciones generosas y el trabajo de nuestros voluntarios, aseguramos que cada persona reciba lo necesario para sentirse cómodo en su día a día.",
    icon: Shirt,
    image: serviceRopero,
  },
  {
    title: "Banco de Alimentos",
    subtitle: "Ayuda mensual",
    description: "Gestión de grandes donaciones y logística de almacenamiento para garantizar la continuidad de nuestras jornadas.",
    icon: Beef,
    image: serviceBanco,
  },
];

// Datos de colaboradores desacoplados
const sponsorImages = import.meta.glob<{ default: ImageMetadata }>('../assets/**/*.{png,webp,jpg,jpeg}', { eager: true });
const sponsorsData = [
  { name: "Banco de Alimentos", logoPath: "../assets/img/banco-alimentos.png" },
  { name: "Shukran", logoPath: "../assets/img/logo-shukran.png" },
  { name: "Amazon", logoPath: "../assets/img/amazon.png" },
  { name: "Altius", logoPath: "../assets/img/logo-altius.png" },
  { name: "La Red de Acción Social", logoPath: "../assets/logos/Logo_red_social.webp" },
  { name: "Remar", logoPath: "../assets/img/logo-remar.png" },
  { name: "Alcamar", logoPath: "../assets/img/logo-alcamar.webp" },
  { name: "AMA", logoPath: "../assets/img/logo-ama.jpg" },
  { name: "Frioval", logoPath: "../assets/img/frioval.jpg" },
  { name: "Comunidad de Madrid", logoPath: "../assets/img/logo-madrid.webp" },
  { name: "Mahou San Miguel", logoPath: "../assets/logos/Logo_Fundacion-Mahou.webp" },
  { name: "Malta +58", logoPath: "../assets/logos/Logo_Malta.webp" },
  { name: "Caixa Bank", logoPath: "../assets/logos/Logo_caixa-bank.jpg" },
  { name: "Los Chamos", logoPath: "../assets/logos/Logo_Chamos.webp" },
  { name: "Luz del Mundo", logoPath: "../assets/logos/Logo_luz_del_mundo.jpg" },
  { name: "CTT", logoPath: "../assets/logos/Logo-ctt-express.webp" },
  { name: "Café Karoma", logoPath: "../assets/logos/Logo_karoma.webp" },
  { name: "Instrelec", logoPath: "../assets/logos/Logo_instrelec.png" },
];

const sponsors = sponsorsData
  .map(s => ({
    name: s.name,
    logo: sponsorImages[s.logoPath]?.default
  }))
  .filter(s => s.logo);
---

<Layout title="ASISVE | Ayuda en acción">
  <link rel="preload" as="image" href={heroImage.src} fetchpriority="high" slot="head" />
  {/* Hero Section */}
  <section class="relative h-[85vh] flex items-center overflow-hidden bg-dark">
    <div class="absolute inset-0 z-0">
      <Image
        src={heroImage}
        class="w-full h-full object-cover opacity-40 scale-105 animate-slow-zoom"
        alt="Voluntarios de ASISVE brindando ayuda humanitaria"
        loading="eager"
        fetchpriority="high"
      />
      <div
        class="absolute inset-0 bg-linear-to-r from-dark via-dark/80 to-transparent"
      >
      </div>
    </div>

    <div class="container max-w-[1320px] mx-auto px-4 relative z-10">
      <div class="max-w-3xl space-y-8">
        <div
          class="inline-flex items-center gap-2 px-6 py-2 rounded-full bg-primary-light/10 border border-primary-light/30 text-white text-sm font-bold animate-fade-in-up backdrop-blur-sm"
        >
          <span class="relative flex h-2.5 w-2.5">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary-light opacity-75"
            ></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-primary-light"
            ></span>
          </span>
          Voces de cambio y dignidad
        </div>
        <h1
          class="text-6xl md:text-8xl text-white font-bold leading-tight animate-fade-in-up"
          style="animation-delay: 200ms"
        >
          ASISVE <br />
          <span class="text-primary-contrast italic">Ayuda en acción</span>
        </h1>

        <p
          class="text-xl text-gray-300 leading-relaxed max-w-xl animate-fade-in-up"
          style="animation-delay: 400ms"
        >
          Nuestra misión es transformar vidas a través de la solidaridad y el
          compromiso social. Súmate como voluntario o colaborador.
        </p>

        <div
          class="flex flex-wrap gap-4 pt-4 animate-fade-in-up"
          style="animation-delay: 600ms"
        >
          <a
            href="/voluntariado"
            class="bg-primary hover:bg-white hover:text-dark text-white px-8 py-4 rounded-full font-bold text-lg transition-all shadow-xl hover:shadow-primary/20 flex items-center gap-2 group"
          >
            Quiero ser voluntario
            <ArrowRight
              class="transition-transform group-hover:translate-x-1"
            />
          </a>
          <a
            href="/testimonial"
            class="border-2 border-white/20 hover:border-white text-white px-8 py-4 rounded-full font-bold text-lg transition-all backdrop-blur-sm"
            aria-label="Ver testimonios de beneficiarios y voluntarios"
          >
            Ver testimonios
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* Services Section */}
  <section class="py-24 bg-gray-50">
    <div class="container mx-auto px-4">
      <div
        class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16 gap-6"
      >
        <div class="max-w-2xl space-y-4">
          <h2 class="text-primary font-bold tracking-widest uppercase text-sm">
            Nuestra Labor
          </h2>
          <h3
            class="text-4xl md:text-5xl font-extrabold text-dark leading-tight"
          >
            Pilares de Ayuda
          </h3>
          <div class="w-20 h-1.5 bg-primary rounded-full"></div>
        </div>
        <p class="text-gray-800 max-w-md font-medium">
          Damos soporte integral a personas en riesgo de exclusión social,
          cubriendo desde necesidades básicas hasta integración laboral.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service, index) => (
          <div class="animate-fade-in-up" style={`animation-delay: ${index * 100}ms`}>
            <ServiceCard {...service} />
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Sponsors Carousel Section */}
  <SponsorsCarousel sponsors={sponsors} />

  {/* Instagram Feed Section */}
  <InstagramFeed />

  {/* Location Section */}
  <Location />
</Layout>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slowZoom {
    from {
      transform: scale(1.05);
    }
    to {
      transform: scale(1.15);
    }
  }

  .animate-fade-in-up {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }

  .animate-slow-zoom {
    animation: slowZoom 20s ease-in-out infinite alternate;
  }
</style>
