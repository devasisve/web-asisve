---
import Layout from '../layouts/Layout.astro';
import { Quote, Star } from 'lucide-astro';
import { Image } from "astro:assets";
import serviceMedica from "../assets/img/jornada-medica.jpg";
import serviceAlimentos from "../assets/img/entrega-alimentos.jpg";
import serviceVoluntariado from "../assets/img/voluntariado.jpg";

const testimonials = [
  {
    name: "María G.",
    role: "Beneficiaria",
    content: "Llegué a Madrid con mucho miedo y sin saber a dónde ir. ASISVE no solo me dio comida, me dio la esperanza y el apoyo legal que necesitaba para empezar de nuevo. Hoy tengo un trabajo digno.",
    image: "/img/avatar-woman-1.webp" // I will use generic ones or placeholders if needed, but since I should generate images or use existing ones... 
  },
  {
    name: "Carlos R.",
    role: "Voluntario",
    content: "Ser parte del ropero solidario me ha cambiado la perspectiva. Ver la sonrisa de un niño cuando recibe ropa limpia es la mejor recompensa. Es una comunidad de amor real.",
    image: "/img/avatar-man-1.webp"
  },
  {
    name: "Elena S.",
    role: "Colaboradora",
    content: "Como médico, poder aportar mi granito de arena en las jornadas de salud de ASISVE es un honor. Atendemos a personas que de otra forma estarían desprotegidas.",
    image: "/img/avatar-woman-2.webp"
  },
  {
    name: "Jesús Silva",
    role: "Beneficiario",
    content: "Gracias a Dios y a la asociación Mano Ayuda, que me abrió las puertas cuando más lo necesitaba. Hoy tengo a mi familia aquí, y eso no hubiera sido posible",
    image: "/img/avatar-man-2.webp"
  },
  {
    name: "Laura Nechita",
    role: "Trabajadora social Diaconia Madrid",
    content: "La gente tiene mucha necesidad de aclarar todas las dudas que tienen, y las de extranjería son las que más dudas se tiene",
    image: "/img/avatar-woman-3.webp"
  },
  {
    name: "Sebastian Salas",
    role: "Beneficiario",
    content: "Agradezco mucho a asociación ASISVE, gracias por regalar los alimentos que nos dan. Es de mucha ayuda a mi y a mi familia.",
    image: "/img/avatar-man-3.webp"
  },
  {
    name: "Juan Carlos Viana",
    role: "Coordinador",
    content: "En nuestra labor, incluimos ayuda alimentaria, ropa de segunda mano, pero en buen estado, integración a la sociedad con la posibilidad de participar como voluntarios, talleres, medicina, trabajo, entre otras.",
    image: "/img/avatar-man-5.webp"
  },
  {
    name: "Owen & María Jóse",
    role: "Beneficiarios",
    content: "Gracias a la ONG y su refugio, encontramos un lugar seguro desde donde",
    image: "/img/avatar-man-6.webp"
  },
  {
    name: "Cesar Obando",
    role: "Coordinador",
    content: "Complacido de trabajar acá de la mano del director general  Ricardo y todo el equipo de voluntarios que siempre lo dan todo en todas las jornadas",
    image: "/img/avatar-man-7.webp"
  },
  {
    name: "Ricardo Mazzini",
    role: "Director General",
    content: "Si entregamos algo, debe hacerse con la misma dedicación que lo haríamos para nosotros mismos. Cada persona que está ahí fuera es como parte de nuestra familia, por lo que es esencial ofrecer productos de calidad",
    image: "/img/avatar-man-8.webp"
  },
  {
    name: "Mari Guerrero",
    role: "Trabajadora social Diaconia Madrid",
    content: "Super agradecida por toda la labor que haceis y encantada de venir a dar los talleres",
    image: "/img/avatar-woman-4.webp"
  },
  {
    name: "Naibert Sánchez",
    role: "Voluntario",
    content: "Lo mejor de ser voluntario es ver a las personas que encuentran algo en el ropero que necesitan en ese momento de manera gratuita y es una bendición de Dios",
    image: "/img/avatar-man-4.webp"
  }
];
---

<Layout title="Testimonios | ASISVE">
  <section class="py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center mb-12 md:mb-20 space-y-6">
        <h2 class="text-primary font-bold tracking-widest uppercase text-sm">Voces de Cambio</h2>
        <h1 class="text-4xl md:text-6xl font-extrabold text-dark leading-tight">
          Historias que <span class="text-primary">inspiran</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-600 leading-relaxed">
          Nuestra labor cobra vida a través de las personas que forman parte de esta gran familia.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-12">
        {testimonials.map((t, index) => (
          <div class="bg-gray-50 p-6 md:p-8 rounded-[32px] relative animate-fade-in-up" style={`animation-delay: ${index * 150}ms`}>
            <Quote size="48" class="text-primary/10 absolute top-6 md:top-8 right-6 md:right-8" />
            <div class="flex gap-1 mb-6">
              {[...Array(5)].map(() => <Star size="16" class="fill-primary text-primary" />)}
            </div>
            <p class="text-gray-700 italic mb-8 leading-relaxed">"{t.content}"</p>
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-primary/20 rounded-full flex items-center justify-center text-primary font-bold">
                {t.name[0]}
              </div>
              <div>
                <h4 class="font-bold text-dark">{t.name}</h4>
                <p class="text-sm text-gray-500">{t.role}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      {/* Impact Section */}
      <div class="mt-20 md:mt-32 text-center space-y-12 overflow-hidden">
        <h3 class="text-2xl md:text-3xl font-bold text-dark italic px-4">"Tu ayuda no es solo una donación, es una oportunidad de vida."</h3>
        <div class="flex justify-center gap-4 md:gap-8 flex-nowrap md:flex-row px-2">
           <Image src={serviceMedica} alt="Jornada" class="w-24 h-24 sm:w-32 sm:h-32 md:w-48 md:h-48 rounded-full object-cover border-4 border-white shadow-xl rotate-3" />
           <Image src={serviceAlimentos} alt="Impacto" class="w-32 h-32 sm:w-40 sm:h-40 md:w-56 md:h-56 rounded-full object-cover border-4 border-white shadow-xl -rotate-3 z-10" />
           <Image src={serviceVoluntariado} alt="Voluntarios" class="w-24 h-24 sm:w-32 sm:h-32 md:w-48 md:h-48 rounded-full object-cover border-4 border-white shadow-xl rotate-6" />
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .animate-fade-in-up {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }
</style>
